# Canonizr Pipeline Configuration
# Copy to .env and adjust as needed, or run ./bin/setup.sh

# Gateway
GATEWAY_PORT=7005
# CORS_ORIGINS=http://localhost:5173

# Captioning (Gemma 4 via llama-server)
CAPTIONING_ENABLED=true
CAPTIONING_MODEL=/models/gemma-4-e4b.gguf
CAPTIONING_MMPROJ=/models/gemma-4-e4b-mmproj-f16.gguf
CAPTIONING_CTX_SIZE=8192
CAPTIONING_N_PREDICT=1024
