#!/usr/bin/env bash
set -euo pipefail

PORT="${CANONIZR_PORT:-7005}"
BASE_URL="http://localhost:${PORT}"

REPO_ROOT="$(cd "$(dirname "$(readlink "$0" || echo "$0")")/.." && pwd)"

usage() {
  echo "Usage: canonizr <command>"
  echo ""
  echo "Commands:"
  echo "  up [--fg] Start the pipeline (--fg for foreground with logs)"
  echo "  down      Stop the pipeline"
  echo "  convert   Convert a file to markdown"
  echo "  health    Check if the service is running"
  echo ""
  echo "Options:"
  echo "  convert [-o <file>] [-f] [-q] <file>"
  echo "    -o <file>   Output path (default: <input>.md)"
  echo "    -o -        Write markdown to stdout instead of file"
  echo "    -f          Overwrite output file if it exists"
  echo "    -q          Quiet mode, suppress job summary"
  exit 1
}

cmd_convert() {
  local force=false
  local quiet=false
  local output=""
  local file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--force) force=true; shift ;;
      -q|--quiet) quiet=true; shift ;;
      -o) shift; output="$1"; shift ;;
      *) file="$1"; shift ;;
    esac
  done

  if [[ -z "$file" ]]; then
    usage
  fi

  if [[ ! -f "$file" ]]; then
    echo "Error: file not found: $file" >&2
    exit 1
  fi

  # Skip files that are already plaintext/markdown
  case "${file##*.}" in
    md|markdown|txt|csv|json|xml|html|py|java|c|h)
      echo "${file} is already a text format, skipping" >&2
      exit 0
      ;;
  esac

  # Default output: <input>.md (e.g. report.pdf -> report.pdf.md)
  if [[ -z "$output" ]]; then
    output="${file}.md"
  fi

  # Check for existing output (unless writing to stdout or force)
  if [[ "$output" != "-" ]] && [[ "$force" != "true" ]] && [[ -f "$output" ]]; then
    echo "${output} already exists, skipping (use -f to overwrite)" >&2
    exit 0
  fi

  # Request markdown body with metadata in header
  local tmpfile tmpbody
  tmpfile=$(mktemp)
  tmpbody=$(mktemp)
  trap 'rm -f "$tmpfile" "$tmpbody"' RETURN

  local http_code metadata

  # Make the request — capture status code, headers, and body separately
  http_code=$(curl -s -o "$tmpbody" -D "$tmpfile" -w "%{http_code}" \
    -H "Accept: text/markdown" \
    -F "file=@${file}" \
    "${BASE_URL}/convert" 2>/dev/null) || {
    echo "Error: could not reach Canonizr at ${BASE_URL}" >&2
    echo "Is the service running? Start it with: canonizr up" >&2
    exit 1
  }

  # Handle HTTP errors
  if [[ "$http_code" -ge 400 ]]; then
    echo "Error (HTTP $http_code): $(cat "$tmpbody")" >&2
    exit 1
  fi

  metadata=$(grep -i '^x-job-metadata:' "$tmpfile" | sed 's/^[^:]*: //' | tr -d '\r')

  if [[ "$output" == "-" ]]; then
    # Pipe mode: markdown to stdout
    cat "$tmpbody"
  else
    # File mode: move body to output, metadata to stdout
    mv "$tmpbody" "$output"
    if [[ "$quiet" != "true" ]] && [[ -n "$metadata" ]]; then
      echo "$metadata"
    fi
  fi
}

cmd_health() {
  curl -sf "${BASE_URL}/health" && echo "" || {
    echo "Error: Canonizr is not running at ${BASE_URL}" >&2
    exit 1
  }
}

_profiles() {
  # Build profile flags based on .env config
  local profiles=""
  if [ "${CAPTIONING_ENABLED:-true}" = "true" ] && [ -z "${CAPTIONING_ENDPOINT:-}" ]; then
    profiles="$profiles --profile captioning"
  fi
  if [ "${LIBREOFFICE_ENABLED:-true}" = "true" ]; then
    profiles="$profiles --profile libreoffice"
  fi
  echo "$profiles"
}

cmd_up() {
  local detach="-d"
  for arg in "$@"; do
    case "$arg" in
      --fg) detach="" ;;
    esac
  done

  cd "$REPO_ROOT"
  source .env 2>/dev/null || true
  docker compose $(_profiles) up $detach --build
}

cmd_down() {
  cd "$REPO_ROOT"
  docker compose --profile captioning --profile libreoffice down
}

if [[ $# -lt 1 ]]; then
  usage
fi

case "$1" in
  up) shift; cmd_up "$@" ;;
  down) cmd_down ;;
  convert) shift; cmd_convert "$@" ;;
  health) cmd_health ;;
  *) usage ;;
esac
